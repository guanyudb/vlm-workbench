# Python
__pycache__/
*.pyc
*.egg-info/
.eggs/

# Virtual envs
.venv/
venv/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp

# Node + Vite build output (regenerable via build.sh)
frontend/node_modules/
frontend/dist/
static/

# Claude / vibe session state (not project content)
.claude/
chat.md

# Local dev artifacts
*.log
.env
module.env

# DAB workspace-UI variable overrides — each workspace has its own values
.databricks/bundle/*/variable-overrides.json
# (the .sample versions ARE committed; see .databricks/bundle/dev/)
!.databricks/bundle/*/variable-overrides.json.sample

# Bundled experiments may write Volume paths into local tmp results
_tmp/
