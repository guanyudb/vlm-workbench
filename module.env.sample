# Copy this file to `module.env` and fill in values for your workspace.
# `deploy.sh` sources this file to set BUNDLE_VAR_* env vars, which the
# Databricks CLI picks up automatically and threads through into the bundle's
# variables.

# Required ---------------------------------------------------------------------

# UC catalog (must already exist; bundle won't create catalogs for safety)
export BUNDLE_VAR_uc_catalog=hls_amer_catalog

# UC schema inside the catalog. The bundle will create it if missing.
export BUNDLE_VAR_uc_schema=guanyu_chen

# SQL warehouse the App SP will use for Delta sync
export BUNDLE_VAR_sql_warehouse_id=18ca4fa4ce58f74c

# Lakebase Postgres instance name
export BUNDLE_VAR_lakebase_instance=lakebasepoc

# Existing secret scope holding the Hugging Face token (for gated models)
export BUNDLE_VAR_hf_secret_scope=hls_g4

# Optional --------------------------------------------------------------------

# UC volume name (under the catalog/schema above). Default: medical_video
# export BUNDLE_VAR_volume_name=medical_video

# Lakebase database name within the instance. Default: vlm_workbench
# export BUNDLE_VAR_lakebase_database=vlm_workbench

# HF secret key. Default: HF_TOKEN
# export BUNDLE_VAR_hf_secret_key=HF_TOKEN

# App name. Default: vlm-workbench
# export BUNDLE_VAR_app_name=vlm-workbench

# Workbench-managed secret scope (catalog/schema/volume names). Default: vlmwb_config
# export BUNDLE_VAR_workbench_secret_scope=vlmwb_config

# Admin group that gets MANAGE on the workbench secret scope. Default: admins
# export BUNDLE_VAR_default_admin_group=admins
